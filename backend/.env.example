# Google Gemini API key — get one at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.0-flash

# Redis URL (optional, for caching)
REDIS_URL=redis://localhost:6379

# Demo mode — serve pre-computed results
DEMO_MODE=true

# Database (SQLite for demo, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./orbital_inspect.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/orbital_inspect

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# Auth (disabled in demo mode)
AUTH_ENABLED=false
JWT_SECRET=dev-secret-change-in-production

# Resilience
AGENT_TIMEOUT_SECONDS=120
JOB_TIMEOUT_SECONDS=300
